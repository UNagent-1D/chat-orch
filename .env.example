# chat-orch environment variables
# Copy this file to .env and fill in values for your environment.

# HTTP bind address
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# [REQUIRED] conversation-chat (Go) base URL
CONVERSATION_CHAT_URL=http://conversation-chat:8082

# [REQUIRED] tenant service (Go) base URL — reserved for future tenant lookups
TENANT_SERVICE_URL=http://tenant:8080

# [REQUIRED] LLM API key (fed by OPENROUTER_API_KEY in compose)
OPENAI_API_KEY=sk-...

# OpenAI-compatible API base URL (default: OpenRouter)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Default model
OPENAI_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Log level filter
RUST_LOG=chat_orch=info,tower_http=info

# Log format: "json" for production, "pretty" for local dev
LOG_FORMAT=pretty

# Metricas KPI service base URL (optional — tap disabled if unset)
# METRICAS_URL=http://metricas:8080

# Hospital Mock API base URL (required — orch calls tools here during LLM turns)
HOSPITAL_MOCK_URL=http://hospital-mock:8080

# Telegram long-poll integration (both required to enable)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DEFAULT_TENANT_ID=demo-tenant

# Origin allowed to hit the orch from the browser
CORS_ALLOW_ORIGIN=http://localhost:3000
